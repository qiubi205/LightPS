<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    android:background="#FF1A1A2E">

    <!-- Layers panel: slideable drawer on right -->
    <com.lightps.ui.LayersPanel
        android:id="@+id/layersPanel"
        android:layout_width="140dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/toolbar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Canvas area -->
    <com.lightps.ui.CanvasView
        android:id="@+id/canvas"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/layersPanel" />

    <!-- Bottom toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FF16213E"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_undo"
                style="@style/ToolButton"
                android:text="↩" />

            <Button
                android:id="@+id/btn_eraser"
                style="@style/ToolButton"
                android:text="Erase" />

            <Button
                android:id="@+id/btn_layers"
                style="@style/ToolButton"
                android:text="Layers" />

            <Button
                android:id="@+id/btn_new_layer"
                style="@style/ToolButton"
                android:text="＋" />

            <Button
                android:id="@+id/btn_del_layer"
                style="@style/ToolButton"
                android:text="−" />

            <Button
                android:id="@+id/btn_color"
                style="@style/ToolButton"
                android:text="Color" />

            <Button
                android:id="@+id/btn_size_down"
                style="@style/ToolButton"
                android:text="−S" />

            <Button
                android:id="@+id/btn_size_up"
                style="@style/ToolButton"
                android:text="+S" />

            <Button
                android:id="@+id/btn_open"
                style="@style/ToolButton"
                android:text="Open" />

            <Button
                android:id="@+id/btn_new"
                style="@style/ToolButton"
                android:text="New" />

            <Button
                android:id="@+id/btn_save"
                style="@style/ToolButton"
                android:text="Save" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
